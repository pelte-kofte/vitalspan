{
  "expo": {
    "name": "Vitalspan",
    "slug": "vitalspan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#EDE8DC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vitalspan.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Vitalspan reads your health data to track biomarkers and biological age.",
        "NSHealthUpdateUsageDescription": "Vitalspan writes workout and health data to Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "eas": {
        "projectId": "4d42a8cb-bf83-4229-82a5-1b2273356a54"
      }
    },
    "android": {
      "package": "com.vitalspan.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2D6A4F"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-font"
    ]
  }
}
