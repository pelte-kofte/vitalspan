{
  "expo": {
    "name": "Vitalspan",
    "slug": "vitalspan",
    "scheme": "vitalspan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0C0F0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vitalspan.app",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": [],
        "aps-environment": "production",
        "com.apple.developer.applesignin": ["Default"]
      },
      "infoPlist": {
        "NSHealthUpdateUsageDescription": "Vitalspan writes workout and health data to Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "eas": {
        "projectId": "4d42a8cb-bf83-4229-82a5-1b2273356a54"
      }
    },
    "android": {
      "package": "com.vitalspan.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2D6A4F"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-font",
      "expo-apple-authentication",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Vitalspan reads your health data to display longevity metrics on your dashboard.",
          "NSHealthUpdateUsageDescription": "Vitalspan writes workout and health data to Apple Health."
        }
      ],
      "react-native-adapty",
      "@react-native-community/datetimepicker",
      ["expo-notifications", { "sounds": [] }]
    ]
  }
}
