EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Local-only token for scripts/brief-admin.mjs. Obtain a short-lived JWT for an
# authenticated user whose protected app_metadata contains brief_admin=true.
# Never prefix this with EXPO_PUBLIC_ or commit a real token.
BRIEF_ADMIN_ACCESS_TOKEN=short-lived-admin-user-jwt
# Alternative local CLI login (do not commit real values):
# BRIEF_ADMIN_EMAIL=editor@example.com
# BRIEF_ADMIN_PASSWORD=local-shell-only
EXPO_PUBLIC_ADAPTY_API_KEY=your_adapty_public_sdk_key_here
